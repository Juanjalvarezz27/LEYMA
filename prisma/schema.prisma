generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- TABLAS DE REFERENCIA ---

model Rol {
  id      Int       @id @default(autoincrement())
  nombre  String    @unique
  usuarios Usuario[]
}

model EstadoOrden {
  id      Int       @id @default(autoincrement())
  nombre  String    @unique
  ordenes Orden[]
}

model TipoDescuento {
  id            Int            @id @default(autoincrement())
  nombre        String         @unique
  ordenes       Orden[]
  detallesOrden DetalleOrden[]
}

model MetodoPago {
  id      Int       @id @default(autoincrement())
  nombre  String    @unique
  pagos   Pago[]
  gastos  Gasto[]
}

// --- MODELOS DE PRUEBAS (Nivel 1, 2 y 3) ---

model CategoriaPrueba {
  id            Int                  @id @default(autoincrement())
  nombre        String               @unique 
  subcategorias SubcategoriaPrueba[]
}

model SubcategoriaPrueba {
  id            String          @id @default(cuid())
  nombre        String
  activa        Boolean         @default(true)
  
  esPaquete     Boolean         @default(false) 
  precioUSD     Float?          // El precio total si es un paquete
  
  categoriaId   Int
  categoria     CategoriaPrueba @relation(fields: [categoriaId], references: [id])
  pruebas       Prueba[]
}

model Prueba {
  id                 String             @id @default(cuid())
  codigo             String             @unique 
  nombre             String             
  
  precioUSD          Float?             
  
  unidades           String?            
  valoresReferencia  String?            
  activa             Boolean            @default(true) 
  ordenVisual        Int                @default(0)
  
  subcategoriaId     String
  subcategoria       SubcategoriaPrueba @relation(fields: [subcategoriaId], references: [id], onDelete: Cascade)
  
  detallesOrden      DetalleOrden[]     
  valoresResultados  ValorResultado[]
}

// --- MODELOS PRINCIPALES ---

model Usuario {
  id                String            @id @default(cuid())
  nombre            String
  correo            String            @unique
  clave             String
  activo            Boolean           @default(true)
  rolId             Int
  rol               Rol               @relation(fields: [rolId], references: [id])
  ordenesCreadas    Orden[]
  gastosRegistrados Gasto[]
  resultadosValidados ResultadoPrueba[]
  fechaCreacion     DateTime          @default(now())
}

model Paciente {
  id              String   @id @default(cuid())
  cedula          String?  @unique
  nombreCompleto  String
  fechaNacimiento DateTime
  esBebe          Boolean  @default(false)
  sexo            String
  telefono        String?
  correo          String?
  direccion       String?
  observaciones   String?  @db.Text
  ordenes         Orden[]
  fechaRegistro   DateTime @default(now())
}

model Orden {
  id                  Int            @id @default(autoincrement())
  pacienteId          String
  paciente            Paciente       @relation(fields: [pacienteId], references: [id])
  usuarioId           String
  creadoPor           Usuario        @relation(fields: [usuarioId], references: [id])
  estadoId            Int
  estado              EstadoOrden    @relation(fields: [estadoId], references: [id])
  subtotalUSD         Float
  descuentoGeneral    Float          @default(0)
  tipoDescuentoId     Int?
  tipoDescuento       TipoDescuento? @relation(fields: [tipoDescuentoId], references: [id])
  totalUSD            Float
  totalBS             Float 
  tasaBCV             Float 
  resultadosCompletados Boolean      @default(false)
  fechaCreacion       DateTime       @default(now())
  pagos               Pago[]
  detalles            DetalleOrden[]
}

model DetalleOrden {
  id                   String             @id @default(cuid())
  ordenId              Int
  orden                Orden              @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  
  pruebaId             String             // Apunta directamente a la prueba cobrada
  prueba               Prueba             @relation(fields: [pruebaId], references: [id])
  
  cantidad             Int                @default(1)
  precioCongeladoUSD   Float 
  descuento            Float              @default(0)
  tipoDescuentoId      Int?
  tipoDescuento        TipoDescuento?     @relation(fields: [tipoDescuentoId], references: [id])
  resultado            ResultadoPrueba?
}

model ResultadoPrueba {
  id             String           @id @default(cuid())
  detalleOrdenId String           @unique
  detalleOrden   DetalleOrden     @relation(fields: [detalleOrdenId], references: [id], onDelete: Cascade)
  usuarioId      String 
  procesadoPor   Usuario          @relation(fields: [usuarioId], references: [id])
  observaciones  String?          @db.Text
  fechaProcesado DateTime         @default(now())
  valores        ValorResultado[]
}

model ValorResultado {
  id                String          @id @default(cuid())
  resultadoId       String
  resultado         ResultadoPrueba @relation(fields: [resultadoId], references: [id], onDelete: Cascade)
  pruebaId          String
  prueba            Prueba          @relation(fields: [pruebaId], references: [id])
  valorIngresado    String          
}

model Pago {
  id          String     @id @default(cuid())
  ordenId     Int
  orden       Orden      @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  metodoId    Int
  metodo      MetodoPago @relation(fields: [metodoId], references: [id])
  montoUSD    Float
  montoBS     Float
  referencia  String? 
  fechaPago   DateTime   @default(now())
}

model Gasto {
  id            String     @id @default(cuid())
  usuarioId     String
  registradoPor Usuario    @relation(fields: [usuarioId], references: [id])
  concepto      String
  metodoId      Int
  metodo        MetodoPago @relation(fields: [metodoId], references: [id])
  montoUSD      Float
  montoBS       Float
  referencia    String?
  fechaGasto    DateTime   @default(now())
}